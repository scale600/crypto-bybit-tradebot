# API Keys
OPENAI_API_KEY=your_openai_api_key_here
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_SECRET_KEY=your_bybit_secret_key_here

# Trading Configuration
TRADING_PAIR=BTCUSDT
LEVERAGE=5
POSITION_SIZE=100
STOP_LOSS_PERCENT=0.5
